# Variáveis públicas expostas ao frontend via Vite (permitido)
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Variáveis usadas no servidor / build (Lovable Cloud injeta automaticamente)
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_URL="https://your-project-ref.supabase.co"

# NUNCA versionar:
# - SUPABASE_SERVICE_ROLE_KEY  (somente Edge Functions)
# - GECKO_API_KEY              (somente Edge Functions / Secrets)
# - OPENAI_API_KEY             (somente Edge Functions / Secrets)
